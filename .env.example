# fish-ai 环境变量配置示例
# 使用 LazyLLM namespace 机制 + FISHAI_ 前缀
# 复制此文件为 .env 或配置到 ~/.config/fish-ai.ini

# ============= 基础配置 =============
# LLM 供应商（支持：openai, anthropic, google, groq, mistral, cohere, deepseek, azure, self-hosted）
FISHAI_PROVIDER=openai

# API 密钥（通用，适用于所有供应商）
FISHAI_API_KEY=sk-your-api-key-here

# 或者使用供应商专用的 API Key 环境变量（推荐，避免混淆）
# FISHAI_OPENAI_API_KEY=sk-...
# FISHAI_DEEPSEEK_API_KEY=sk-...
# FISHAI_GROQ_API_KEY=gsk-...
# FISHAI_ANTHROPIC_API_KEY=sk-ant-...
# FISHAI_MISTRAL_API_KEY=...

# 模型名称（可选，有默认值）
FISHAI_MODEL=gpt-4o

# ============= 可选配置 =============
# 自定义服务器地址（用于自托管或 Azure）
# FISHAI_SERVER=https://api.openai.com/v1

# Azure 配置
# FISHAI_PROVIDER=azure
# FISHAI_SERVER=https://your-instance.openai.azure.com
# FISHAI_AZURE_DEPLOYMENT=your-deployment-name

# 自托管配置（兼容 OpenAI 协议）
# FISHAI_PROVIDER=self-hosted
# FISHAI_SERVER=http://localhost:8000/v1

# DeepSeek 配置（自动使用 DeepSeek API）
# FISHAI_PROVIDER=deepseek
# FISHAI_MODEL=deepseek-chat

# Groq 配置
# FISHAI_PROVIDER=groq
# FISHAI_MODEL=qwen/qwen3-32b

# Anthropic 配置
# FISHAI_PROVIDER=anthropic
# FISHAI_MODEL=claude-sonnet-4-6

# Google Gemini 配置
# FISHAI_PROVIDER=google
# FISHAI_MODEL=gemini-2.5-flash-lite

# Mistral 配置
# FISHAI_PROVIDER=mistral
# FISHAI_MODEL=mistral-large-latest
# FISHAI_SERVER=https://api.mistral.ai

# Cohere 配置
# FISHAI_PROVIDER=cohere
# FISHAI_MODEL=command-r-plus-08-2024

# ============= 高级配置 =============
# 自定义 HTTP 请求头（用于 Cloudflare Access 等）
# FISHAI_HEADERS=CF-Access-Client-Id: xxx, CF-Access-Client-Secret: yyy

# OpenAI 组织 ID
# FISHAI_ORGANIZATION=org-xxx

# 额外参数（JSON 格式）
# FISHAI_EXTRA_BODY={"temperature": 0.7, "max_tokens": 1000}

# ============= LazyLLM 通用配置 =============
# LazyLLM 日志级别
# LAZYLLM_LOG_LEVEL=INFO

# ============= 一键切换供应商示例 =============
# 从 OpenAI 切换到 Anthropic：
# 1. 修改 FISHAI_PROVIDER=anthropic
# 2. 修改 FISHAI_API_KEY=your-anthropic-key
# 3. 修改 FISHAI_MODEL=claude-sonnet-4-6
# 无需修改代码！
